{
  "permissions": {
    "allow": [
      "Bash(uv run *)",
      "Bash(git checkout *)",
      "Bash(git push origin dev*)",
      "Bash(git push --set-upstream origin dev*)",
      "Bash(gh pr create *)"
    ],
    "deny": [
      "Bash(git push origin main*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)"
    ]
  }
}
